# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/

# Coverage and test reports
.coverage
.coverage.*
htmlcov/

# Virtual environments and packaging
.venv/
venv/
env/
dist/
build/
pip-wheel-metadata/
*.egg-info/

# Local environment files
.env
.env.*
!.env.example

# Editor and OS files
.claude/
.idea/
.vscode/
.DS_Store
Thumbs.db
*.log

# Local experiment outputs and heavyweight data.
# Keep lightweight, verifiable artifacts of the primary zh120 benchmark
# (metrics, reports, significance, patch decisions) in the repo, but not
# regenerable heavyweight files (vectors, chunks, per-query traces).
runs/*
!runs/zh120_*/
runs/zh120_*/*vectors*.json
runs/zh120_*/chunks.json
runs/zh120_*/*retrieval_results*.json
runs/zh120_*/hybrid_bm25_results.json
datasets/
tools/qdrant/storage/
tools/qdrant/qdrant
tools/qdrant/.qdrant-initialized

# Personal docs and interview prep
project_docs/
reranker_finetune/

# Generated files for public auxiliary experiments
experiments/**/data/
experiments/**/outputs/
experiments/**/models/
experiments/**/*.safetensors
